# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database (local Docker)
DATABASE_URL=postgresql://lumen:lumen@localhost:5432/lumen_ai

# Redis (Phase 2 - optional locally)
REDIS_URL=redis://localhost:6379

# Auth.js - generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-random-secret
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
ENABLE_MOCK_AUTH=true
# Fallback to in-memory mock catalog only when DB is empty/unavailable
ENABLE_MOCK_CATALOG=false

# Local file uploads when R2 is not configured (dev)
UPLOAD_DIR=./uploads

# Google OAuth - https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth - https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Sole admin email (everyone else is CUSTOMER). Defaults in code if unset.
ADMIN_EMAIL=brandon.sardelli@gmail.com

# Cloudflare R2 - https://dash.cloudflare.com/
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=lumen-ai-assets

# Stripe - https://dashboard.stripe.com/
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SUBSCRIPTION_PRICE_ID=
STRIPE_YEARLY_SUBSCRIPTION_PRICE_ID=

# Resend - https://resend.com/
RESEND_API_KEY=
EMAIL_FROM=orders@lumenai.com
